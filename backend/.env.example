# AI (Claude CLI — uses ANTHROPIC_API_KEY from shell env, not needed here)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# Data source tokens (公开标识，非个人密钥)
EASTMONEY_UT=fa5fd1943c7b386f172d6893dbfba10b
# Local RSS aggregator URL (RSSHUB)
RSSHUB_URL=http://localhost:18080/news

# CORS allowed origins (comma-separated, defaults to localhost:3000,localhost:8000)
CORS_ORIGINS=

# Frontend static files path
FRONTEND_PATH=

# Binance SSL verify ("1"=verify, "0"=skip, defaults to verify)
BINANCE_SSL_VERIFY=1
